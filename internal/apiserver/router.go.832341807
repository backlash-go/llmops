package apiserver

import (
	"github.com/gin-gonic/gin"
	"github.com/marmotedu/component-base/pkg/core"
	"github.com/marmotedu/errors"

	"llmops/internal/apiserver/store/mysql"
	"llmops/internal/pkg/code"
	genericoptions "llmops/internal/pkg/options"

	"llmops/internal/apiserver/router"

	 "llmops/internal/apiserver/controller/v1/login"

	// custom gin validators.
	_ "llmops/pkg/validator"
)

func initRouter(g *gin.Engine, oauth *genericoptions.OAuthOptions) {
	installMiddleware(g)
	installController(g)
	ApplyOauthConfig(oauth)
}

func ApplyOauthConfig(oauth *genericoptions.OAuthOptions) {
	login.OauthConfig.AuthorizationEndpoint = oauth.AuthorizationEndpoint
	login.OauthConfig.ClientID =         oauth.ClientID
	login.OauthConfig.RedirectURI=         oauth.RedirectURI
	login.OauthConfig.Scopes =               oauth.Scopes
	login.OauthConfig.StateTTL =             oauth.StateTTL
	login.OauthConfig.CookieSecure =        oauth.CookieSecure
		
}


func installMiddleware(g *gin.Engine) {
}

func installController(g *gin.Engine) *gin.Engine {
	// Middlewares.

	g.NoRoute(func(c *gin.Context) {
		core.WriteResponse(c, errors.WithCode(code.ErrPageNotFound, "Page not found."), nil)
	})

	// v1 handlers, requiring authentication
	storeIns, _ := mysql.GetMySQLFactoryOr(nil)

	router.RegisterLoginRoutes(g)

	v1 := g.Group("/ops/api/v1")

	router.RegisterUserRoutes(storeIns, v1)

	return g
}
